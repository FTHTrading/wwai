// FIFA Troptions — Prisma Schema
// Player card trading + options platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ── Users / Wallets ─────────────────────────────────────────────
model User {
  id          String   @id @default(cuid())
  address     String   @unique          // wallet public key / apostle agent UUID
  chain       String   @default("apo")  // "apo" | "evm" | "sol"
  displayName String?
  createdAt   DateTime @default(now())

  listings    Listing[]
  bids        Bid[]
  optionsBought  OptionContract[] @relation("Buyer")
  optionsSold    OptionContract[] @relation("Seller")
}

// ── FIFA Player Cards ────────────────────────────────────────────
model PlayerCard {
  id          String   @id @default(cuid())
  eaId        String   @unique          // EA FC / FIFA internal ID
  name        String
  club        String
  league      String
  nation      String
  position    String
  rating      Int
  rarity      String   @default("gold") // gold | silver | bronze | special | icon | hero
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  listings    Listing[]
  options     OptionContract[]
  priceHistory PriceSnapshot[]
}

// ── Market Listings (buy/sell order book) ───────────────────────
model Listing {
  id          String   @id @default(cuid())
  cardId      String
  sellerId    String
  price       Float                     // in ATP
  currency    String   @default("ATP")
  quantity    Int      @default(1)
  status      String   @default("open") // open | filled | cancelled
  txHash      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  card        PlayerCard @relation(fields: [cardId], references: [id])
  seller      User       @relation(fields: [sellerId], references: [id])
  bids        Bid[]
}

model Bid {
  id          String   @id @default(cuid())
  listingId   String
  bidderId    String
  amount      Float
  currency    String   @default("ATP")
  status      String   @default("pending") // pending | accepted | rejected | expired
  createdAt   DateTime @default(now())

  listing     Listing @relation(fields: [listingId], references: [id])
  bidder      User    @relation(fields: [bidderId], references: [id])
}

// ── Options Contracts ────────────────────────────────────────────
model OptionContract {
  id              String   @id @default(cuid())
  cardId          String
  buyerId         String
  sellerId        String
  strikePrice     Float                         // ATP
  premium         Float                         // ATP paid upfront
  currency        String   @default("ATP")
  contractType    String   @default("call")     // call | put
  expiresAt       DateTime
  status          String   @default("open")     // open | exercised | expired | cancelled
  exercisedTxHash String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  card    PlayerCard @relation(fields: [cardId], references: [id])
  buyer   User       @relation("Buyer",  fields: [buyerId],  references: [id])
  seller  User       @relation("Seller", fields: [sellerId], references: [id])
}

// ── Price History ────────────────────────────────────────────────
model PriceSnapshot {
  id        String   @id @default(cuid())
  cardId    String
  price     Float
  source    String   @default("market") // market | futbin | futwiz
  recordedAt DateTime @default(now())

  card      PlayerCard @relation(fields: [cardId], references: [id])
}

// ═══════════════════════════════════════════════════════════════
// PHASE 2 — TROPTIONS SALES OPERATING SYSTEM
// ═══════════════════════════════════════════════════════════════

// ── Sponsors ─────────────────────────────────────────────────────
model Sponsor {
  id            String   @id @default(cuid())
  name          String
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  package       String   @default("smart")     // smart | cultural | rewards
  status        String   @default("prospect")  // prospect | active | paused | closed
  budget        Float?
  industry      String?
  website       String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  campaigns     Campaign[]
  leads         Lead[]
}

// ── Venues ───────────────────────────────────────────────────────
model Venue {
  id            String   @id @default(cuid())
  name          String
  address       String?
  city          String   @default("Atlanta")
  lat           Float?
  lng           Float?
  category      String   @default("general") // stadium | hotel | transit | entertainment | food | retail | general
  capacity      Int?
  contactName   String?
  contactEmail  String?
  contactPhone  String?
  status        String   @default("prospect") // prospect | onboarded | active | inactive
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  campaigns     Campaign[]
  leads         Lead[]
}

// ── Campaigns ────────────────────────────────────────────────────
model Campaign {
  id          String   @id @default(cuid())
  name        String
  sponsorId   String?
  venueId     String?
  type        String   @default("qr")    // qr | offer | event | digital
  status      String   @default("draft") // draft | active | paused | completed
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  impressions Int      @default(0)
  clicks      Int      @default(0)
  redemptions Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sponsor     Sponsor?  @relation(fields: [sponsorId], references: [id])
  venue       Venue?    @relation(fields: [venueId],   references: [id])
  qrCodes     QrCode[]
}

// ── QR Codes & Redemptions ───────────────────────────────────────
model QrCode {
  id          String   @id @default(cuid())
  campaignId  String
  code        String   @unique @default(cuid())
  label       String?
  offerText   String?
  rewardValue Float?
  rewardType  String   @default("discount") // discount | points | free_item | cashback
  scans       Int      @default(0)
  redemptions Int      @default(0)
  active      Boolean  @default(true)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  campaign    Campaign  @relation(fields: [campaignId], references: [id])
  events      QrEvent[]
}

model QrEvent {
  id         String   @id @default(cuid())
  qrCodeId   String
  eventType  String   @default("scan") // scan | redeem | share
  ipHash     String?  // SHA-256 hashed for privacy
  userAgent  String?
  location   String?
  createdAt  DateTime @default(now())

  qrCode     QrCode   @relation(fields: [qrCodeId], references: [id])
}

// ── Leads ────────────────────────────────────────────────────────
model Lead {
  id             String   @id @default(cuid())
  type           String   @default("sponsor") // sponsor | venue | sales | general
  name           String
  email          String?
  phone          String?
  company        String?
  message        String?
  source         String   @default("web")  // web | qr | referral | cold
  status         String   @default("new")  // new | contacted | qualified | converted | lost
  estimatedValue Float?
  sponsorId      String?
  venueId        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sponsor        Sponsor? @relation(fields: [sponsorId], references: [id])
  venue          Venue?   @relation(fields: [venueId],   references: [id])
}
