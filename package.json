{
  "name": "fifa-troptions",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed": "npx tsx prisma/seed.ts",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:reset:demo": "prisma migrate reset --force && npx tsx prisma/seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "deploy:cf": "npx @cloudflare/next-on-pages@1 && npx wrangler pages deploy .vercel/output/static --project-name=troptions-fifa",
    "deploy:cf:preview": "npx @cloudflare/next-on-pages@1 && npx wrangler pages deploy .vercel/output/static --project-name=troptions-fifa --branch=preview",
    "deploy": "powershell -ExecutionPolicy Bypass -File scripts/deploy.ps1 -Prod",
    "deploy:preview": "powershell -ExecutionPolicy Bypass -File scripts/deploy.ps1",
    "preflight": "powershell -ExecutionPolicy Bypass -File scripts/preflight.ps1",
    "smoke": "powershell -ExecutionPolicy Bypass -File scripts/smoke.ps1",
    "release:vercel": "pwsh -ExecutionPolicy Bypass -File scripts/vercel-release.ps1",
    "deploy:check": "npm run preflight && npm run lint && npx tsc --noEmit && npm run build",
    "test:wwai": "pwsh -ExecutionPolicy Bypass -File scripts/test-wwai.ps1",
    "postinstall": "prisma generate",
    "ai:health": "powershell -ExecutionPolicy Bypass -File ./ops/local-ai/health-check.ps1",
    "ai:test:nim": "powershell -ExecutionPolicy Bypass -File ./ops/local-ai/test-nim-chat.ps1",
    "ai:test:app": "powershell -ExecutionPolicy Bypass -File ./ops/local-ai/test-app-ai-routes.ps1 -Port 3002",
    "docker:safe-status": "powershell -ExecutionPolicy Bypass -File ./ops/local-ai/docker-safe-status.ps1"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/better-sqlite3": "^7.6.13",
    "axios": "^1.15.2",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "maplibre-gl": "^5.24.0",
    "next": "16.2.4",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^3.114.17"
  }
}
