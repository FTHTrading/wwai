# env.example — Local AI Control Plane environment reference
# Copy relevant values to your actual .env / Windows user environment.
# NEVER commit real keys to git.

# ── NIM ─────────────────────────────────────────────────────────────────────
# NGC API key for NVIDIA NIM containers
# Set in Windows user env: [System.Environment]::SetEnvironmentVariable("NGC_API_KEY","<key>","User")
NGC_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NIM endpoint (from Windows host)
NIM_BASE_URL=http://localhost:8800/v1

# NIM endpoint (from inside Docker containers, e.g. Open WebUI)
NIM_BASE_URL_DOCKER=http://host.docker.internal:8800/v1

# Default model served by NIM
NIM_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1

# Max context length passed at container start (NIM_MAX_MODEL_LEN)
NIM_MAX_MODEL_LEN=16384

# ── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Open WebUI ───────────────────────────────────────────────────────────────
OPEN_WEBUI_URL=http://localhost:3001

# ── NeedAI ───────────────────────────────────────────────────────────────────
NEEDAI_URL=http://localhost:3000

# ── Apostle Chain ────────────────────────────────────────────────────────────
APOSTLE_CHAIN_URL=http://localhost:7332
APOSTLE_CHAIN_ID=7332

# ── Infra Stack ──────────────────────────────────────────────────────────────
INFRA_API_URL=http://localhost:8010
INFRA_LLM_URL=http://localhost:8011
INFRA_POSTGRES_URL=postgresql://localhost:5433
INFRA_REDIS_URL=redis://localhost:6381

# ── Wilkins Stack ────────────────────────────────────────────────────────────
WILKINS_POSTGRES_URL=postgresql://localhost:5455
WILKINS_REDIS_URL=redis://localhost:6380

# ── FIFA Troptions App ───────────────────────────────────────────────────────
# Add these to C:\Users\Kevan\fifa troptions\.env.local when AI routes are built
NEXT_PUBLIC_NIM_BASE_URL=http://localhost:8800/v1
NEXT_PUBLIC_NIM_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
# Server-side only (do not prefix with NEXT_PUBLIC_):
NIM_BASE_URL=http://localhost:8800/v1
